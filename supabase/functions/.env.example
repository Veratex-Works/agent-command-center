# Copy to supabase/functions/.env for local `supabase functions serve` (never commit secrets).
# In Supabase Cloud, set secrets in the dashboard or `supabase secrets set`.

# Required for deploy-bot (forwarding to automation)
N8N_DEPLOY_WEBHOOK_URL=https://your-n8n-host/webhook/your-path

# Injected automatically when deployed; needed for local serve:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
