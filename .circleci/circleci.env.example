# Example only — fake values. Do not use in production.
# Copy to a local file, replace with real values, then enter each key in
# CircleCI: https://app.circleci.com/ → your project → Project Settings → Environment Variables
#
# Required:
VPS_HOST=203.0.113.10
VPS_USER=deploy
VPS_DEPLOY_PATH=/var/www/openclaw
# PEM must include BEGIN/END lines. In a .env file, multiline values in double quotes:
SSH_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA7example+FAKE+KEY+DO+NOT+USE+IN+PRODUCTION
-----END RSA PRIVATE KEY-----"
#
# Optional:
VPS_SSH_PORT=22
#
# Optional — same as repo root `.env.example` (web build):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key
