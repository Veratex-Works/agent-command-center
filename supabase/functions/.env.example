# Copy to supabase/functions/.env for local `supabase functions serve` (never commit secrets).
# In Supabase Cloud, set secrets in the dashboard or `supabase secrets set`.

# Required for deploy-bot (forwarding to automation)
N8N_DEPLOY_WEBHOOK_URL=https://your-n8n-host/webhook/your-path

# Optional: n8n “Test URL” (or test workflow) for superadmin “Test n8n” in the app
N8N_DEPLOY_WEBHOOK_TEST_URL=https://your-n8n-host/webhook-test/your-path

# Shared secret for POST /functions/v1/deploy-bot-callback (header: x-deploy-callback-secret)
DEPLOY_BOT_CALLBACK_SECRET=generate-a-long-random-string

# Same value on the n8n server as $env.N8N_COMPOSE_FETCH_SECRET — POST body to deploy-webhook-compose
N8N_COMPOSE_FETCH_SECRET=generate-a-different-long-random-string

# Injected automatically when deployed; needed for local serve:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
