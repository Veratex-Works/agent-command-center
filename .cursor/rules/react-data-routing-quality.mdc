## ROUTING (React Router v6+)

- Use `createBrowserRouter` with the data router API — not the legacy `<BrowserRouter>` + JSX tree approach
- Define all routes in `src/router/index.tsx` — one source of truth for the route tree
- Use nested routes and `<Outlet />` for shared layouts (nav, sidebar, auth guards)
- Use route-level `lazy` for code splitting — don't eagerly import every page
- Use `useNavigate` for programmatic navigation, never `window.location`
- Use `useParams` and `useSearchParams` for reading URL state — don't duplicate URL data into component state
- Protect private routes with a layout-level auth guard component, not per-page checks

```tsx
// src/router/index.tsx
import { createBrowserRouter } from 'react-router-dom'
import { lazy, Suspense } from 'react'

const DashboardPage = lazy(() => import('@/modules/dashboard/DashboardPage'))
const UsersPage = lazy(() => import('@/modules/users/UsersPage'))

export const router = createBrowserRouter([
  {
    path: '/',
    element: <RootLayout />,       // nav, sidebar, toast provider
    children: [
      {
        element: <AuthGuard />,    // redirects to /login if unauthenticated
        children: [
          {
            path: 'dashboard',
            element: (
              <Suspense fallback={<PageSkeleton />}>
                <DashboardPage />
              </Suspense>
            ),
          },
          {
            path: 'users',
            element: (
              <Suspense fallback={<PageSkeleton />}>
                <UsersPage />
              </Suspense>
            ),
          },
        ],
      },
      { path: 'login', element: <LoginPage /> },
    ],
  },
])
```

```tsx
// src/App.tsx
import { RouterProvider } from 'react-router-dom'
import { router } from '@/router'

export default function App() {
  return <RouterProvider router={router} />
}
```

